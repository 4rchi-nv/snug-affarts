---
const leftMenuItems = ["Проекты", "Направления", "О нас"];
const languages = ["RU", "EN"];
---

<header class="site-header">
  <div class="container site-header__inner">
    <div class="site-header__left">
      <button class="site-header__burger" type="button" aria-label="Open menu">
        <span></span>
        <span></span>
      </button>
      <!-- TODO: replace with real top navigation links -->
      <nav aria-label="Main navigation">
        <ul class="site-header__menu">
          {leftMenuItems.map((item) => <li><a href="#">{item}</a></li>)}
        </ul>
      </nav>
    </div>

    <a href="/" class="site-header__logo">Snug.</a>

    <div class="site-header__right">
      <a href="#" class="site-header__search">Поиск</a>
      <div class="site-header__langs" aria-label="Language switcher">
        {languages.map((lang) => <a href="#">{lang}</a>)}
      </div>
      <a href="tel:+74952302550" class="site-header__phone">+7 495 230 25 50</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(0, 0, 0, 0.3);
    border-bottom: 1px solid rgba(0, 0, 0, 0.3);
  }

  .site-header__inner {
    min-height: 56px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
  }

  .site-header__left,
  .site-header__right {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-width: 0;
  }

  .site-header__right {
    justify-self: end;
  }

  .site-header__burger {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 28px;
    height: 28px;
    border: 0;
    background: transparent;
    padding: 0;
    cursor: pointer;
  }

  .site-header__burger span {
    width: 18px;
    height: 1px;
    background: #f3f3f3;
  }

  .site-header__menu {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    gap: 1.1rem;
  }

  .site-header__menu a,
  .site-header__search,
  .site-header__langs a,
  .site-header__phone {
    color: #ededed;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .site-header__logo {
    color: #ffffff;
    text-decoration: none;
    font-weight: 700;
    letter-spacing: 0.02em;
    justify-self: center;
  }

  .site-header__langs {
    display: inline-flex;
    gap: 0.4rem;
    padding-right: 0.6rem;
    border-right: 1px solid #5c5c5f;
  }

  .site-header__phone {
    font-size: 0.7rem;
    letter-spacing: 0.03em;
  }

  @media (max-width: 1024px) {
    .site-header__menu,
    .site-header__search,
    .site-header__phone {
      display: none;
    }

    .site-header__inner {
      grid-template-columns: auto 1fr auto;
    }

    .site-header__logo {
      justify-self: start;
      margin-left: 0.25rem;
    }
  }

  @media (max-width: 640px) {
    .site-header__inner {
      min-height: 52px;
    }

    .site-header__langs a {
      font-size: 0.68rem;
    }
  }
</style>
